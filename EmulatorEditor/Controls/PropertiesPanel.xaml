<UserControl x:Class="EmulatorEditor.Controls.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="HeaderLabel">
            <Setter Property="Foreground"  Value="#585B70"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionLabel">
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="FontSize"    Value="11"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="Margin"      Value="0,0,0,6"/>
        </Style>
        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Background"   Value="#313244"/>
            <Setter Property="Foreground"   Value="#CDD6F4"/>
            <Setter Property="BorderBrush"  Value="#45475A"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="Margin"       Value="0,0,0,8"/>
        </Style>
        <Style TargetType="Button" x:Key="SmallButton">
            <Setter Property="Background"  Value="#45475A"/>
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="8,3"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontSize"    Value="11"/>
        </Style>
        <Style TargetType="Button" x:Key="DeleteButton">
            <Setter Property="Background"  Value="#F38BA8"/>
            <Setter Property="Foreground"  Value="#1E1E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="4,1"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="FontSize"    Value="10"/>
        </Style>
        <Style TargetType="ComboBox" x:Key="InputCombo"
               BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Background"  Value="#313244"/>
            <Setter Property="Foreground"  Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding"     Value="4,3"/>
            <Setter Property="Margin"      Value="0,0,0,8"/>
        </Style>

        <!-- Dark TabItem style -->
        <Style TargetType="TabItem">
            <Setter Property="Background"  Value="#2A2A3E"/>
            <Setter Property="Foreground"  Value="#A6ADC8"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding"     Value="10,5"/>
            <Setter Property="FontSize"    Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E1E2E"/>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background"       Value="#1E1E2E"/>
            <Setter Property="BorderBrush"      Value="#45475A"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="0"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel x:Name="RootPanel" Margin="12">

            <TextBlock x:Name="EmptyText" Text="Select an object to edit"
                       Foreground="#585B70" HorizontalAlignment="Center"
                       Margin="0,40,0,0"/>

            <StackPanel x:Name="EditPanel" Visibility="Collapsed">

                <!-- ── BASIC INFO (항상 표시) ───────────────────────────────── -->
                <TextBlock Text="BASIC INFO" Style="{StaticResource SectionLabel}"/>

                <TextBlock Text="MachineId" Style="{StaticResource Label}"/>
                <TextBox x:Name="MachineIdBox" Style="{StaticResource InputBox}"/>

                <TextBlock Text="UnitId" Style="{StaticResource Label}"/>
                <TextBox x:Name="UnitIdBox" Style="{StaticResource InputBox}"
                         TextChanged="UnitIdBox_TextChanged"/>

                <TextBlock Text="Type" Style="{StaticResource Label}"/>
                <ComboBox x:Name="TypeCombo" Style="{StaticResource InputCombo}"
                          SelectionChanged="TypeCombo_SelectionChanged">
                    <ComboBoxItem>Robot</ComboBoxItem>
                    <ComboBoxItem>AGV</ComboBoxItem>
                    <ComboBoxItem>Conveyor</ComboBoxItem>
                    <ComboBoxItem>Sensor</ComboBoxItem>
                    <ComboBoxItem>PLC</ComboBoxItem>
                </ComboBox>

                <Separator Background="#45475A" Margin="0,4,0,10"/>

                <!-- ── 메인 탭 (Connection / Properties) ───────────────────── -->
                <TabControl Margin="0,0,0,10">

                    <!-- ═══════════════ Connection ═══════════════ -->
                    <TabItem Header="Connection">
                        <StackPanel Margin="8,8,8,8">

                            <TextBlock Text="Protocol" Style="{StaticResource Label}"/>
                            <ComboBox x:Name="ProtocolCombo" Style="{StaticResource InputCombo}"
                                      SelectionChanged="ProtocolCombo_SelectionChanged">
                                <ComboBoxItem Tag="mqtt">MQTT</ComboBoxItem>
                                <ComboBoxItem Tag="rest">REST API</ComboBoxItem>
                                <ComboBoxItem Tag="websocket" IsEnabled="False" Foreground="#585B70">WebSocket  (준비 중)</ComboBoxItem>
                                <ComboBoxItem Tag="opcua"     IsEnabled="False" Foreground="#585B70">OPC-UA  (준비 중)</ComboBoxItem>
                                <ComboBoxItem Tag="modbus"    IsEnabled="False" Foreground="#585B70">Modbus TCP  (준비 중)</ComboBoxItem>
                                <ComboBoxItem Tag="ros2"      IsEnabled="False" Foreground="#585B70">ROS2  (준비 중)</ComboBoxItem>
                                <ComboBoxItem Tag="grpc"      IsEnabled="False" Foreground="#585B70">gRPC  (준비 중)</ComboBoxItem>
                            </ComboBox>

                            <!-- MQTT section ──────────────────────────────── -->
                            <StackPanel x:Name="MqttSection">

                                <TextBlock Text="Broker" Style="{StaticResource Label}"/>
                                <ComboBox x:Name="BrokerCombo" Style="{StaticResource InputCombo}"/>

                                <!-- MQTT 내부 탭: XCP / Topics -->
                                <TabControl Margin="0,0,0,0">

                                    <!-- ── XCP 탭 ── -->
                                    <TabItem Header="XCP">
                                        <StackPanel Margin="8,8,8,8">

                                            <CheckBox x:Name="UsesXcpCheck" Content="Depends on XCP"
                                                      Foreground="#CDD6F4" FontSize="11" Margin="0,0,0,10"
                                                      Checked="UsesXcpCheck_Changed"
                                                      Unchecked="UsesXcpCheck_Changed"/>

                                            <StackPanel x:Name="XcpPanel" Visibility="Collapsed">

                                                <!-- prefix / identifier -->
                                                <Grid Margin="0,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Prefix"     Style="{StaticResource Label}"/>
                                                        <TextBox   x:Name="XcpPrefixBox" Text="xflow" Style="{StaticResource InputBox}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Identifier" Style="{StaticResource Label}"/>
                                                        <TextBox   x:Name="XcpIdentifierBox" Text="rcp" Style="{StaticResource InputBox}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- version / target -->
                                                <Grid Margin="0,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Version" Style="{StaticResource Label}"/>
                                                        <TextBox   x:Name="XcpVersionBox" Text="v1" Style="{StaticResource InputBox}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource Label}">
                                                            <Run Text="Target"/>
                                                            <Run Text=" (default: UnitId)" Foreground="#585B70"/>
                                                        </TextBlock>
                                                        <TextBox x:Name="XcpTargetBox" Style="{StaticResource InputBox}"
                                                                 ToolTip="비워두면 UnitId를 사용합니다"
                                                                 TextChanged="XcpTargetBox_TextChanged"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Subscribe Commands -->
                                                <TextBlock Text="Subscribe Commands" Style="{StaticResource Label}" Margin="0,4,0,6"/>
                                                <WrapPanel Margin="0,0,0,4">
                                                    <!-- Fixed (항상 구독, 수정 불가) -->
                                                    <CheckBox Content="status" IsChecked="True" IsEnabled="False"
                                                              Foreground="#585B70" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox Content="sync"   IsChecked="True" IsEnabled="False"
                                                              Foreground="#585B70" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox Content="auto"   IsChecked="True" IsEnabled="False"
                                                              Foreground="#585B70" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox Content="manual" IsChecked="True" IsEnabled="False"
                                                              Foreground="#585B70" FontSize="11" Margin="0,0,12,6"/>
                                                    <!-- Optional (선택 가능) -->
                                                    <CheckBox x:Name="XcpStart"  Content="start"  Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox x:Name="XcpStop"   Content="stop"   Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox x:Name="XcpPause"  Content="pause"  Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox x:Name="XcpResume" Content="resume" Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox x:Name="XcpAbort"  Content="abort"  Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                    <CheckBox x:Name="XcpEnd"    Content="end"    Foreground="#CDD6F4" FontSize="11" Margin="0,0,12,6"/>
                                                </WrapPanel>

                                            </StackPanel>
                                        </StackPanel>
                                    </TabItem>

                                    <!-- ── Topics 탭 ── -->
                                    <TabItem Header="Topics">
                                        <StackPanel Margin="8,8,8,8">

                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock Text="Subscribe Topics" Style="{StaticResource Label}"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="+ Add" Style="{StaticResource SmallButton}"
                                                        HorizontalAlignment="Right" Click="AddSubscribeTopic_Click"/>
                                            </DockPanel>
                                            <ItemsControl x:Name="SubscribeTopicList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#2A2A3E" CornerRadius="4"
                                                                Padding="8" Margin="0,2,0,2">
                                                            <StackPanel>
                                                                <DockPanel>
                                                                    <Button Content="X" Style="{StaticResource DeleteButton}"
                                                                            DockPanel.Dock="Right" VerticalAlignment="Center"
                                                                            Tag="{Binding}" Click="RemoveSubscribeTopic_Click"/>
                                                                    <TextBox Text="{Binding Topic, UpdateSourceTrigger=PropertyChanged}"
                                                                             Background="#313244" Foreground="#CDD6F4"
                                                                             BorderBrush="#45475A" Padding="4,2"/>
                                                                </DockPanel>
                                                                <DockPanel Margin="0,6,0,2">
                                                                    <TextBlock Text="Parse Fields" Foreground="#A6ADC8"
                                                                               FontSize="10" VerticalAlignment="Center"/>
                                                                    <Button Content="+ Field" Style="{StaticResource SmallButton}"
                                                                            HorizontalAlignment="Right" FontSize="10"
                                                                            Tag="{Binding}" Click="AddParseField_Click"/>
                                                                </DockPanel>
                                                                <Grid Margin="0,2,20,0">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="56"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="key"     Style="{StaticResource HeaderLabel}"/>
                                                                    <TextBlock Grid.Column="1" Text="type"    Style="{StaticResource HeaderLabel}" Margin="2,0"/>
                                                                    <TextBlock Grid.Column="2" Text="maps_to" Style="{StaticResource HeaderLabel}" Margin="2,0"/>
                                                                </Grid>
                                                                <ItemsControl ItemsSource="{Binding ParseFields}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,2">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="56"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="20"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBox Grid.Column="0"
                                                                                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                                                         Background="#313244" Foreground="#CDD6F4"
                                                                                         BorderBrush="#45475A" Padding="3,2"/>
                                                                                <ComboBox Grid.Column="1" Margin="2,0"
                                                                                          SelectedValue="{Binding Type, Mode=TwoWay}"
                                                                                          SelectedValuePath="Content"
                                                                                          Background="#313244" Foreground="#CDD6F4"
                                                                                          BorderBrush="#45475A" Padding="2,1" FontSize="10"
                                                                                          Style="{StaticResource InputCombo}">
                                                                                    <ComboBoxItem>string</ComboBoxItem>
                                                                                    <ComboBoxItem>float</ComboBoxItem>
                                                                                    <ComboBoxItem>bool</ComboBoxItem>
                                                                                </ComboBox>
                                                                                <TextBox Grid.Column="2"
                                                                                         Text="{Binding MapsTo, UpdateSourceTrigger=PropertyChanged}"
                                                                                         Background="#313244" Foreground="#A6E3A1"
                                                                                         BorderBrush="#45475A" Padding="3,2"/>
                                                                                <Button Grid.Column="3" Content="X"
                                                                                        Style="{StaticResource DeleteButton}"
                                                                                        Padding="2,1" FontSize="9"
                                                                                        Tag="{Binding}" Click="RemoveParseField_Click"/>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <DockPanel Margin="0,10,0,4">
                                                <TextBlock Text="Publish Topics" Style="{StaticResource Label}"
                                                           VerticalAlignment="Center"/>
                                                <Button Content="+ Add" Style="{StaticResource SmallButton}"
                                                        HorizontalAlignment="Right" Click="AddPublishTopic_Click"/>
                                            </DockPanel>
                                            <ItemsControl x:Name="PublishTopicList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="0,2">
                                                            <Button Content="X" Style="{StaticResource DeleteButton}"
                                                                    DockPanel.Dock="Right" VerticalAlignment="Center"
                                                                    Tag="{Binding}" Click="RemovePublishTopic_Click"/>
                                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                                     Background="#313244" Foreground="#CDD6F4"
                                                                     BorderBrush="#45475A" Padding="4,2"/>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                        </StackPanel>
                                    </TabItem>

                                </TabControl>
                            </StackPanel>

                            <!-- URL-based section (REST, WebSocket 등) -->
                            <StackPanel x:Name="UrlSection" Visibility="Collapsed">
                                <TextBlock x:Name="ConnectionUrlLabel" Text="Endpoint URL"
                                           Style="{StaticResource Label}"/>
                                <TextBox x:Name="ConnectionUrlBox" Style="{StaticResource InputBox}"/>
                                <StackPanel x:Name="RestListenPathPanel" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource Label}">
                                        <Run Text="Listen Path"/>
                                        <Run Text=" (inbound, e.g. /robot/1)" Foreground="#585B70"/>
                                    </TextBlock>
                                    <TextBox x:Name="RestListenPathBox" Style="{StaticResource InputBox}"
                                             Text="/robot/1"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Modbus TCP section -->
                            <StackPanel x:Name="ModbusSection" Visibility="Collapsed">
                                <TextBlock Text="Host"    Style="{StaticResource Label}"/>
                                <TextBox x:Name="ModbusHostBox"   Style="{StaticResource InputBox}" Text="localhost"/>
                                <TextBlock Text="Port"    Style="{StaticResource Label}"/>
                                <TextBox x:Name="ModbusPortBox"   Style="{StaticResource InputBox}" Text="502"/>
                                <TextBlock Text="Unit ID" Style="{StaticResource Label}"/>
                                <TextBox x:Name="ModbusUnitIdBox" Style="{StaticResource InputBox}" Text="1"/>
                            </StackPanel>

                        </StackPanel>
                    </TabItem>

                    <!-- ═══════════════ Properties ═══════════════ -->
                    <TabItem Header="Properties">
                        <StackPanel Margin="8,8,8,8">

                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="PROPERTIES" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                                <Button Content="+ Add" Style="{StaticResource SmallButton}"
                                        HorizontalAlignment="Right" Click="AddProperty_Click"/>
                            </DockPanel>

                            <!-- header row -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="1" Text="Name"    Style="{StaticResource HeaderLabel}"/>
                                <TextBlock Grid.Column="2" Text="Type"    Style="{StaticResource HeaderLabel}" Margin="2,0"/>
                                <TextBlock Grid.Column="3" Text="Default" Style="{StaticResource HeaderLabel}" Margin="2,0"/>
                            </Grid>

                            <ItemsControl x:Name="PropertyList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2,0,0">
                                            <!-- Main row -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Key}"
                                                           Foreground="#CDD6F4" FontSize="11"
                                                           VerticalAlignment="Center" Margin="4,0,2,0"
                                                           Visibility="{Binding IsPredefined, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#313244" Foreground="#CDD6F4"
                                                         BorderBrush="#45475A" Padding="4,2" Margin="0,0,2,0"
                                                         Visibility="{Binding IsNameEditable, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Type}"
                                                           Foreground="#A6ADC8" FontSize="10"
                                                           VerticalAlignment="Center" Margin="2,0"
                                                           Visibility="{Binding IsPredefined, Converter={StaticResource BoolToVis}}"/>
                                                <ComboBox Grid.Column="2" Margin="2,0"
                                                          SelectedValue="{Binding Type, Mode=TwoWay}"
                                                          SelectedValuePath="Content"
                                                          Background="#313244" Foreground="#CDD6F4"
                                                          BorderBrush="#45475A" FontSize="10"
                                                          Visibility="{Binding IsNameEditable, Converter={StaticResource BoolToVis}}">
                                                    <ComboBoxItem>string</ComboBoxItem>
                                                    <ComboBoxItem>int</ComboBoxItem>
                                                    <ComboBoxItem>float</ComboBoxItem>
                                                    <ComboBoxItem>bool</ComboBoxItem>
                                                    <ComboBoxItem>enum</ComboBoxItem>
                                                    <ComboBoxItem>button</ComboBoxItem>
                                                </ComboBox>
                                                <CheckBox Grid.Column="3" Margin="6,0"
                                                          IsChecked="{Binding BoolDefaultValue}"
                                                          Foreground="#CDD6F4" VerticalAlignment="Center"
                                                          Visibility="{Binding IsBool, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Grid.Column="3" Margin="2,0"
                                                         Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#313244" Foreground="#F9E2AF"
                                                         BorderBrush="#45475A" Padding="4,2"
                                                         ToolTip="Initial value (must be one of the enum values)"
                                                         Visibility="{Binding IsEnum, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Grid.Column="3" Margin="4,0"
                                                           Text="→ below" Foreground="#585B70" FontSize="10"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding IsButton, Converter={StaticResource BoolToVis}}"/>
                                                <TextBox Grid.Column="3" Margin="2,0"
                                                         Text="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Background="#313244" Foreground="#F9E2AF"
                                                         BorderBrush="#45475A" Padding="4,2"
                                                         Visibility="{Binding IsValueEditable, Converter={StaticResource BoolToVis}}"/>
                                                <Button Grid.Column="4" Content="×"
                                                        Style="{StaticResource DeleteButton}"
                                                        Padding="2,0" FontSize="13"
                                                        VerticalAlignment="Center"
                                                        Tag="{Binding}" Click="DeleteProperty_Click"
                                                        Visibility="{Binding IsNameEditable, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>

                                            <!-- Enum values editor -->
                                            <Border Margin="22,3,0,3" Padding="8,6"
                                                    Background="#1E1E2E" CornerRadius="4"
                                                    Visibility="{Binding IsEnum, Converter={StaticResource BoolToVis}}">
                                                <StackPanel>
                                                    <TextBlock Foreground="#A6ADC8" FontSize="10" Margin="0,0,0,3">
                                                        <Run Text="Values"/>
                                                        <Run Text=" (comma-separated)" Foreground="#585B70"/>
                                                    </TextBlock>
                                                    <TextBox Text="{Binding EnumValuesRaw, UpdateSourceTrigger=PropertyChanged}"
                                                             Background="#313244" Foreground="#A6E3A1"
                                                             BorderBrush="#45475A" Padding="4,3"
                                                             FontFamily="Consolas" FontSize="11"
                                                             ToolTip="e.g.  Auto, Manual, Idle"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Button editor -->
                                            <Border Margin="22,3,0,3" Padding="8,6"
                                                    Background="#1E1E2E" CornerRadius="4"
                                                    Visibility="{Binding IsButton, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Foreground="#A6ADC8" FontSize="10" Margin="0,0,0,3">
                                                            <Run Text="Topic"/>
                                                            <Run Text=" (empty = all publish topics)" Foreground="#585B70"/>
                                                        </TextBlock>
                                                        <TextBox Text="{Binding OnClickTopic, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="#313244" Foreground="#89DCEB"
                                                                 BorderBrush="#45475A" Padding="4,3" FontSize="11"
                                                                 ToolTip="MQTT topic to publish to on click"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Foreground="#A6ADC8" FontSize="10" Margin="0,0,0,3">
                                                            <Run Text="Payload"/>
                                                            <Run Text=" (JSON)" Foreground="#585B70"/>
                                                        </TextBlock>
                                                        <TextBox Text="{Binding OnClickPayload, UpdateSourceTrigger=PropertyChanged}"
                                                                 Background="#313244" Foreground="#FAB387"
                                                                 BorderBrush="#45475A" Padding="4,3" FontSize="11"
                                                                 FontFamily="Consolas"
                                                                 ToolTip="JSON payload to publish"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </TabItem>

                </TabControl>

                <!-- ── Apply / Delete (항상 하단) ────────────────────────────── -->
                <Separator Background="#45475A" Margin="0,4,0,10"/>
                <DockPanel>
                    <Button Content="Delete Object" Background="#F38BA8" Foreground="#1E1E2E"
                            BorderThickness="0" Padding="8,6"
                            Cursor="Hand" Click="DeleteObject_Click"
                            DockPanel.Dock="Right"/>
                    <Button Content="Apply" Background="#89B4FA" Foreground="#1E1E2E"
                            BorderThickness="0" Padding="12,6" FontWeight="Bold"
                            Cursor="Hand" Click="Apply_Click"/>
                </DockPanel>

            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
