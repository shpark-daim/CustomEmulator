<UserControl x:Class="EmulatorEditor.Controls.ObjectCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Cursor="SizeAll">
    <Border x:Name="CardBorder"
            Background="#313244" CornerRadius="6"
            BorderBrush="#45475A" BorderThickness="1"
            MinWidth="120" Padding="0">
        <StackPanel>
            <!-- Header -->
            <Border Background="#45475A" CornerRadius="6,6,0,0" Padding="8,4">
                <StackPanel>
                    <TextBlock x:Name="UnitIdText" Text=""
                               Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="12"/>
                    <TextBlock x:Name="TitleText" Text="Object"
                               Foreground="#A6ADC8" FontSize="10" Opacity="0.8"/>
                </StackPanel>
            </Border>
            <!-- Type badge -->
            <Border Padding="8,4,8,2">
                <TextBlock x:Name="TypeText" Text="Robot"
                           Foreground="#89B4FA" FontSize="11"/>
            </Border>
            <!-- Properties -->
            <ItemsControl x:Name="PropList" Margin="8,0,8,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   Foreground="#A6ADC8" FontSize="10"
                                   Margin="0,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
