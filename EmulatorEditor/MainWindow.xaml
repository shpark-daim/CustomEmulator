<Window x:Class="EmulatorEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:EmulatorEditor.Controls"
        Title="Emulator Editor" Height="700" Width="1200"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButton">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#181825" Padding="6,3"
                BorderBrush="#45475A" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource ToolbarButton}" Content="New" Click="New_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Load" Click="Load_Click"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Save" Click="Save_Click"/>
                </StackPanel>
                <TextBlock x:Name="VersionText"
                           Foreground="#585B70" FontSize="10"
                           VerticalAlignment="Center" Margin="6,0"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Object List -->
            <Border Grid.Column="0" Background="#181825"
                    BorderBrush="#45475A" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#313244" Padding="8,6">
                        <TextBlock Text="Objects" Foreground="#CDD6F4" FontWeight="SemiBold"/>
                    </Border>
                    <Button DockPanel.Dock="Top" Content="+ Add Object"
                            Style="{StaticResource ToolbarButton}"
                            Margin="8,8,8,4" Click="AddObject_Click"/>
                    <ListBox x:Name="ObjectList"
                             Background="Transparent" BorderThickness="0"
                             Foreground="#CDD6F4"
                             SelectionChanged="ObjectList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="⬡ " Foreground="#89B4FA"/>
                                    <Run Text="{Binding MachineId}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Center: Editor Canvas -->
            <Border Grid.Column="1" Background="#1E1E2E">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <Canvas x:Name="EditorCanvas" Width="2000" Height="2000"
                            Background="#1E1E2E"
                            MouseLeftButtonDown="Canvas_MouseLeftButtonDown"/>
                </ScrollViewer>
            </Border>

            <!-- Right: Properties Panel -->
            <Border Grid.Column="2" Background="#181825"
                    BorderBrush="#45475A" BorderThickness="1,0,0,0">
                <controls:PropertiesPanel x:Name="PropertiesPanel"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
