<UserControl x:Class="Emulator.Controls.ObjectCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.ContextMenu>
        <ContextMenu Background="#313244" BorderBrush="#585B70" BorderThickness="1">
            <MenuItem Header="연결 정보" Click="ShowInfo_Click">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="MenuItem">
                                    <Border x:Name="Bd" Background="#313244" Padding="12,6"
                                            TextElement.Foreground="#CDD6F4"
                                            TextElement.FontSize="12">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#45475A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </MenuItem.Style>
            </MenuItem>
        </ContextMenu>
    </UserControl.ContextMenu>
    <Border Background="#313244" CornerRadius="6"
            BorderBrush="{Binding StatusBrush}" BorderThickness="1.5"
            MinWidth="190" MaxWidth="250"
            Margin="8">
        <StackPanel>

            <!-- ── Header ── -->
            <Border CornerRadius="5,5,0,0" Padding="8,6"
                    Background="#2A2A3E">
                <DockPanel>
                    <!-- Connect/Disconnect toggle -->
                    <Button Content="{Binding ConnectLabel}"
                            DockPanel.Dock="Right"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{Binding StatusBrush}" FontSize="15" Padding="6,0"
                            Cursor="Hand"
                            ToolTip="{Binding ConnectTip}"
                            Click="ConnectToggle_Click"/>
                    <StackPanel>
                        <TextBlock Text="{Binding UnitId}"
                                   Foreground="#CDD6F4" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#A6ADC8" FontSize="10" Opacity="0.7"/>
                            <TextBlock Text=" · " Foreground="#585B70" FontSize="10"/>
                            <TextBlock Text="{Binding Type}"
                                       Foreground="#A6ADC8" FontSize="10" Opacity="0.7"/>
                            <TextBlock Text=" · " Foreground="#585B70" FontSize="10"/>
                            <TextBlock Text="{Binding Protocol}"
                                       Foreground="#A6ADC8" FontSize="10" Opacity="0.7"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ── Progress Bar ── -->
            <ProgressBar Value="{Binding Progress, Mode=OneWay}"
                         Minimum="0" Maximum="100"
                         Height="24" Margin="0,4,0,0"
                         Foreground="#A6E3A1"
                         Background="#45475A"
                         BorderThickness="0"/>

            <!-- ── Properties ── -->
            <ItemsControl ItemsSource="{Binding Properties}" Margin="8,6,8,8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Key label: visible for all non-button types -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Key}"
                                       Foreground="#A6ADC8" FontSize="11"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsNotButton,
                                           Converter={StaticResource BoolToVis}}"/>

                            <!-- bool → interactive CheckBox (클릭 시 값 토글 + 발행) -->
                            <CheckBox Grid.Column="1"
                                      IsChecked="{Binding Value, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Tag="{Binding}"
                                      Click="BoolCheckBox_Click"
                                      Visibility="{Binding IsBool,
                                          Converter={StaticResource BoolToVis}}"/>

                            <!-- string / int / float → TextBlock -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value}"
                                       Foreground="#CDD6F4" FontSize="11"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsText,
                                           Converter={StaticResource BoolToVis}}"/>

                            <!-- enum → ComboBox (user can select state) -->
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding EnumValues}"
                                      SelectedItem="{Binding Value}"
                                      MinWidth="80" FontSize="11"
                                      Background="#45475A" Foreground="#CDD6F4"
                                      BorderBrush="#585B70"
                                      Visibility="{Binding IsEnum,
                                          Converter={StaticResource BoolToVis}}"/>

                            <!-- button → spans both columns -->
                            <Button Grid.Column="0" Grid.ColumnSpan="2"
                                    Content="{Binding Key}"
                                    FontSize="11" Padding="0,4"
                                    HorizontalAlignment="Stretch"
                                    Tag="{Binding}"
                                    Visibility="{Binding IsButton,
                                        Converter={StaticResource BoolToVis}}"
                                    Click="PropertyButton_Click"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
