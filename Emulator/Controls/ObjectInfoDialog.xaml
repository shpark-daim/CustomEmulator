<Window x:Class="Emulator.Controls.ObjectInfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#1E1E2E" Foreground="#CDD6F4"
        Width="400" SizeToContent="Height" MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">

    <StackPanel Margin="16,12,16,16">

        <!-- Title -->
        <TextBlock FontSize="13" FontWeight="Bold" Foreground="#CDD6F4" Margin="0,0,0,2"
                   Text="{Binding UnitId}"/>
        <TextBlock FontSize="10" Foreground="#6C7086" Margin="0,0,0,10">
            <Run Text="{Binding Name}"/>
            <Run Text=" · "/>
            <Run Text="{Binding Type}"/>
            <Run Text=" · "/>
            <Run Text="{Binding Protocol}" FontStyle="Italic"/>
        </TextBlock>

        <!-- ── XCP ── -->
        <StackPanel Visibility="{Binding UsesXcp, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,10">
            <TextBlock Text="XCP" FontSize="10" FontWeight="Bold"
                       Foreground="#585B70" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Prefix"     Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding XcpPrefix}"     Foreground="#CBA6F7" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Identifier" Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding XcpIdentifier}" Foreground="#CBA6F7" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Version"    Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding XcpVersion}"    Foreground="#CBA6F7" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Target"     Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding XcpTarget}"     Foreground="#CBA6F7" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <Rectangle Height="1" Fill="#313244" Margin="0,0,0,10"/>

        <!-- ── REST ── -->
        <StackPanel Visibility="{Binding IsRest, Converter={StaticResource BoolToVis}}">

            <!-- Callback URL (설정된 경우만) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                        Visibility="{Binding HasRestCallback, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="→ " Foreground="#A6E3A1" FontSize="11"/>
                <TextBlock Text="{Binding RestCallbackUrl}" Foreground="#CDD6F4"
                           FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 엔드포인트 목록 -->
            <TextBlock Text="ENDPOINTS" FontSize="10" FontWeight="Bold"
                       Foreground="#585B70" Margin="0,0,0,5"/>
            <ItemsControl ItemsSource="{Binding RestEndpoints}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#CDD6F4" Margin="0,1"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

        <!-- ── MQTT ── -->
        <StackPanel Visibility="{Binding IsMqtt, Converter={StaticResource BoolToVis}}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Broker" Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding BrokerAddress}"
                           Foreground="#CDD6F4" FontSize="11" FontFamily="Consolas"/>
            </Grid>

            <!-- Subscribe / Publish 좌우 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="← SUBSCRIBE" FontSize="10" FontWeight="Bold"
                               Foreground="#585B70" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding SubscribeTopics}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#89B4FA"
                                           FontSize="10" FontFamily="Consolas"
                                           TextWrapping="Wrap" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="→ PUBLISH" FontSize="10" FontWeight="Bold"
                               Foreground="#585B70" Margin="0,0,0,4"/>
                    <ItemsControl ItemsSource="{Binding PublishTopics}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#A6E3A1"
                                           FontSize="10" FontFamily="Consolas"
                                           TextWrapping="Wrap" Margin="0,1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </StackPanel>

    </StackPanel>
</Window>
