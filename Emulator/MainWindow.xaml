<Window x:Class="Emulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Emulator" Height="650" Width="1100"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButton"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin"  Value="4,0"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ToolbarInput">
            <Setter Property="Background"             Value="#313244"/>
            <Setter Property="Foreground"             Value="#CDD6F4"/>
            <Setter Property="BorderBrush"            Value="#45475A"/>
            <Setter Property="Padding"                Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── 툴바 ── -->
        <Border DockPanel.Dock="Top" Background="#181825" Padding="8,6"
                BorderBrush="#45475A" BorderThickness="0,0,0,1">
            <DockPanel>

                <!-- 오른쪽: 연결 버튼 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="전체 연결" Style="{StaticResource ToolbarButton}"
                            Click="ConnectAll_Click"
                            Background="#A6E3A1" Foreground="#1E1E2E"/>
                    <Button Content="전체 해제" Style="{StaticResource ToolbarButton}"
                            Click="DisconnectAll_Click"
                            Background="#F38BA8" Foreground="#1E1E2E"/>
                </StackPanel>

                <!-- 왼쪽: 설정 + 파일 열기 + 파일명 -->
                <StackPanel Orientation="Horizontal">
                    <Button Content="⚙" Style="{StaticResource ToolbarButton}"
                            ToolTip="설정" Click="Settings_Click"
                            Padding="10,6"/>
                    <Button Content="config.json 열기" Style="{StaticResource ToolbarButton}"
                            Click="OpenConfig_Click"/>

                    <!-- 파일명: 짧게 표시, 툴팁=전체경로, 클릭=클립보드 복사 -->
                    <Button x:Name="ConfigPathBtn"
                            Visibility="Collapsed"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#585B70" FontSize="11"
                            Padding="6,0" Cursor="Hand"
                            Click="ConfigPath_Click"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent"
                                        CornerRadius="3" Padding="6,3">
                                    <TextBlock x:Name="txt"
                                               Text="{TemplateBinding Tag}"
                                               Foreground="#585B70" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd"  Property="Background" Value="#2A2A3C"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="#A6ADC8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ── 캔버스: 에디터 위치 그대로 반영 ── -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Canvas x:Name="ObjectCanvas" Background="#1E1E2E"
                    Width="3000" Height="3000"/>
        </ScrollViewer>

    </DockPanel>
</Window>
